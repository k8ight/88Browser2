<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:configChanges="orientation|screenSize"
    android:fitsSystemWindows="true"
    android:background="@color/dark"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/button2"
        android:hint=""
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="2dp"
        android:backgroundTint="@color/white"
        android:background="@drawable/ic_home" />

    <Button
        android:id="@+id/button4"
        style="@android:style/Animation.Activity"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentTop="true"
        android:layout_marginStart="2dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:padding="8dp"
        android:layout_marginBottom="2dp"
        android:textSize="0sp"
        android:layout_toEndOf="@+id/button2"
        android:background="@drawable/ic_lock"
        tools:hint="" />

    <EditText
        android:id="@+id/editText"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_alignParentTop="true"
        android:layout_marginStart="2dp"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="2dp"
        android:layout_toStartOf="@+id/tabs"
        android:layout_toEndOf="@+id/button4"
        android:autofillHints=""
        android:ems="10"
        android:fontFamily="sans-serif"
        android:hint="@string/type_search_terms"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:selectAllOnFocus="true"
        android:singleLine="true"
        android:textSize="18sp"
        android:textFontWeight="600"
        android:textStyle="bold" />

    <Button
        android:id="@+id/menubtn"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:background="@drawable/list"
        android:hint=""
        android:backgroundTint="@color/white"
        android:visibility="visible" />
    <Button
        android:id="@+id/tabs"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentTop="true"
        android:layout_toStartOf="@+id/menubtn"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:background="@drawable/ic_tabs"
        android:hint="0"
        android:textSize="12dp"
        android:textColor="#fff"
        android:textColorHint="#fff"
        android:visibility="visible"/>
    <ProgressBar
        android:id="@+id/progressBar1"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="419dp"
        android:layout_height="8dp"
        android:layout_below="@+id/editText"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="0dp"
        android:layout_marginTop="-7dp"
        android:layout_marginEnd="0dp"
        android:max="100"
        android:progress="100"
        android:progressDrawable="@drawable/bluex"
        app:layout_constraintBottom_toBottomOf="@+id/editText"

        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editText"
        tools:visibility="visible" />

   <!-- <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="669dp"
        android:layout_below="@+id/editText"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="0dp"
        android:layout_marginTop="3dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp">

    </WebView> -->

    <RelativeLayout
        android:id="@+id/web_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/editText"
        android:layout_marginTop="3dp"/>
    <View
        android:id="@+id/menu_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:visibility="gone"/>
    <LinearLayout
        android:id="@+id/MenuView"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/progressBar1"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="5dp"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="6dp"
        android:elevation="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <ImageButton
                android:id="@+id/back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                app:tint="@null"
                android:padding="1dp"
                android:scaleType="fitCenter"
                android:background="@android:color/transparent"/>

            <ImageButton
                android:id="@+id/refresh"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_refresh"
                app:tint="@null"
                android:padding="1dp"
                android:scaleType="fitCenter"
                android:background="@android:color/transparent"/>

            <ImageButton
                android:id="@+id/fwd"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_fwd"
                app:tint="@null"
                android:padding="1dp"
                android:scaleType="fitCenter"
                android:background="@android:color/transparent"/>

            <ImageButton
                android:id="@+id/downlod"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_download"
                app:tint="@null"
                android:padding="1dp"
                android:scaleType="fitCenter"
                android:background="@android:color/transparent"/>

        </LinearLayout>

        <Button
            android:id="@+id/print"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/print"/>

        <Button
            android:id="@+id/psrc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/src"/>

        <Button
            android:id="@+id/button5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rateus"/>

    </LinearLayout>


</RelativeLayout>